rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /orders/{orderId} {
      allow read, write: if isAuthenticated();
      
      match /items/{itemId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
